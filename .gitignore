# Local dev infra (não commitar)
docker-compose.yml

# Python
__pycache__/
*.pyc
*.pyo
venv/
.env
.env.*

# Storage (dados de usuário — jamais versionar)
storage/training_videos/*
storage/training_frames/*
storage/streams/*
storage/training/*
storage/models/active/*.pt
!storage/**/.gitkeep

# Logs
logs/*.log

# Node
frontend/node_modules/
frontend/dist/

# Model weights (não commitar — usar R2/download)
*.pt
*.onnx
*.pth
*.weights
*.gguf
*.bin
training/*.gguf
# Exceção: modelo demo da landing page (necessário para deploy)
!landing-page/public/models/*.onnx

# OMC state (sessão local do agente)
.omc/

# Temporários
*.tmp
*.bak
.DS_Store

# RTSP Simulator
backend/scripts/bin/
backend/scripts/test_videos/*.mp4
landing-page/node_modules/
