# Local dev infra (não commitar)
docker-compose.yml

# Claude Code — configurações locais (nunca versionar; não devem trippar o driver)
.claude/settings.local.json
**/.claude/settings.local.json

# Secrets & credentials (NUNCA versionar)
.env*
*.pem
*.key
*.db
secrets/

# Python
__pycache__/
*.pyc
*.pyo
venv/

# Storage (dados de usuário — jamais versionar)
storage/training_videos/*
storage/training_frames/*
storage/streams/*
storage/training/*
storage/models/active/*.pt
!storage/**/.gitkeep

# Logs
logs/*.log

# Node
node_modules/
frontend/node_modules/
# DEAD path pré-Fase 0, mantido como comentário histórico
# frontend/dist/

# Model weights (não commitar — usar R2/download)
*.pt
*.onnx
*.pth
*.weights
*.gguf
*.bin
training/*.gguf
# Exceção: modelo demo da landing page (necessário para deploy)
!apps/landing/public/models/*.onnx

# OMC state (sessão local do agente)
.omc/

# Temporários
*.tmp
*.bak
.DS_Store

# RTSP Simulator
services/api/scripts/bin/
services/api/scripts/test_videos/*.mp4

# Adicionado em 2026-05-28 — Limpeza pós-Fase 0
# Motivo: arquivos de cache, build output e runtime data vazaram pro
# tracking. Ver docs/runbooks/phase-0-issues.md

# Test coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Runtime data (storage de labels YOLO, NUNCA versionar)
storage/
services/api/storage/

# Frontend build output (Vite/React)
apps/frontend/dist/
apps/frontend/.vite/

# Landing build output (Astro)
apps/landing/dist/
apps/landing/.astro/

# Manter modelos públicos da landing (intencionalmente versionados)
!apps/landing/public/models/*.onnx
tools/agent-driver/runs/
