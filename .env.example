# ============================================================
# EPI Monitor V2 — Environment Variables
# Railway injeta DATABASE_URL e REDIS_URL automaticamente.
# ============================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=gere-com-python-c-import-secrets-secrets.token_hex-32
SERVICE_TYPE=api

# --- JWT ---
JWT_SECRET_KEY=gere-com-python-c-import-secrets-secrets.token_hex-32
JWT_EXPIRY_HOURS=24

# --- Database (Railway PostgreSQL plugin) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/epi_monitor

# --- Redis (Railway Redis plugin) ---
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 (object storage) ---
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=epi-monitor
R2_KEY=your_access_key_id
R2_SECRET=your_secret_access_key

# --- CORS (produção: URL do frontend Railway) ---
CORS_ORIGINS=http://localhost:3000

# --- Camera encryption (Fernet key) ---
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CAMERA_SECRET_KEY=

# --- Ultralytics Hub (treinamento em nuvem) ---
ULTRALYTICS_HUB_API_KEY=sua_chave_do_hub
ULTRALYTICS_HUB_PROJECT_ID=id_do_projeto_no_hub

# --- Worker ---
WORKER_ID=worker-1
YOLO_MODEL_PATH=yolov8n.pt
DETECTION_CONFIDENCE=0.5

# --- Admin (criado automaticamente no primeiro deploy) ---
ADMIN_EMAIL=admin@epimonitor.com
ADMIN_PASSWORD=EpiMonitor@2024!
ADMIN_NAME=Administrador

# --- Frontend (Vite env vars — prefixo VITE_) ---
VITE_API_URL=http://localhost:5001
VITE_WS_URL=ws://localhost:5001
