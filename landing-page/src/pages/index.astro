---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import HowItWorks from '../components/HowItWorks.astro'
import ModuleCards from '../components/ModuleCards.astro'
import DemoCamera from '../components/DemoCamera.tsx'
---

<Layout title="Visão Computacional para Segurança Industrial">
  <Hero />

  <!-- Demo IA -->
  <section id="demo" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-2 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Teste Nossa IA</h2>
        <p class="text-lg text-gray-500">
          Detectamos EPIs usando sua câmera, diretamente no navegador.
          Sem enviar dados para servidores. Sessão de 15 minutos.
        </p>
      </div>
      <DemoCamera client:only="react" />
    </div>
  </section>

  <HowItWorks />
  <ModuleCards />

  <!-- CTA -->
  <section class="py-20 bg-orange-500">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Pronto para começar?</h2>
      <p class="text-orange-100 text-lg mb-8">
        Configure em minutos. Resultados em tempo real desde o primeiro dia.
      </p>
      <a
        href="https://app.epimonitor.com.br"
        class="inline-block px-8 py-4 bg-white text-orange-600 rounded-xl font-bold text-lg hover:bg-orange-50 transition shadow-lg"
      >
        Começar gratuitamente →
      </a>
    </div>
  </section>
</Layout>
