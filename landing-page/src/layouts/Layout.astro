---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Plataforma de reconhecimento por visão computacional industrial. Detecte EPIs, veículos, produtos e comportamentos em tempo real com IA nas câmeras que você já tem.'
} = Astro.props
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title} | Recognition by CATH</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
