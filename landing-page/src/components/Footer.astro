---
const year = new Date().getFullYear()
---

<footer class="bg-gray-900 text-gray-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-sm">EPI</span>
        </div>
        <span class="font-bold text-white">Monitor</span>
      </div>

      <div class="flex gap-6 text-sm">
        <a href="mailto:contato@epimonitor.com.br" class="hover:text-white transition">Contato</a>
        <a href="/termos" class="hover:text-white transition">Termos de Uso</a>
        <a href="/privacidade" class="hover:text-white transition">Privacidade</a>
      </div>

      <p class="text-sm">© {year} EPI Monitor. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
