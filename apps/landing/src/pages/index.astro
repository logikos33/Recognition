---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import HowItWorks from '../components/HowItWorks.astro'
import RecognitionPossibilities from '../components/RecognitionPossibilities.astro'
import UseCases from '../components/UseCases.astro'
import ModuleCards from '../components/ModuleCards.astro'

const APP_URL = import.meta.env.PUBLIC_APP_URL || 'https://frontend-production-bf96.up.railway.app'
---

<Layout title="Visão Computacional Industrial">
  <Hero />
  <HowItWorks />
  <RecognitionPossibilities />
  <UseCases />
  <ModuleCards />

  <!-- CTA -->
  <section class="py-20 bg-orange-500">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Pronto para começar?</h2>
      <p class="text-orange-100 text-lg mb-8">
        Configure em minutos. Resultados em tempo real desde o primeiro frame.
      </p>
      <a
        href={APP_URL}
        class="inline-block px-8 py-4 bg-white text-orange-600 rounded-xl font-bold text-lg hover:bg-orange-50 transition shadow-lg"
      >
        Começar gratuitamente →
      </a>
    </div>
  </section>
</Layout>
