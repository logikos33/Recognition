---
import Layout from '../layouts/Layout.astro'
---

<Layout
  title="Tecnologia"
  description="Como funciona a detecção de EPIs: YOLOv8, DINO, SAM e streaming HLS em tempo real."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-4">Tecnologia</h1>
      <p class="text-xl text-gray-300">
        Stack de visão computacional de última geração para ambientes industriais.
      </p>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-10 text-center">Componentes Principais</h2>

      <div class="grid md:grid-cols-2 gap-8">
        {[
          {
            icon: '🎯',
            title: 'YOLOv8 — Detecção em Tempo Real',
            desc: 'Modelo state-of-the-art para detecção de objetos. Processa frames a 5 FPS com latência < 200ms. Treinável com dados próprios via interface web.',
            tags: ['PyTorch', 'Ultralytics', '5 FPS'],
          },
          {
            icon: '🔍',
            title: 'Grounding DINO — Pré-anotação',
            desc: 'Detecção baseada em linguagem natural. "helmet . safety vest . gloves" → boxes automáticos. Reduz tempo de anotação em 70%.',
            tags: ['Zero-shot', 'Texto → Boxes', 'Auto-label'],
          },
          {
            icon: '✂️',
            title: 'SAM — Segmentação Precisa',
            desc: 'Segment Anything Model refina os bounding boxes gerados pelo DINO para máxima precisão nas anotações.',
            tags: ['Meta AI', 'ViT-B', 'Refinamento'],
          },
          {
            icon: '📡',
            title: 'Streaming HLS',
            desc: 'FFmpeg transcodifica RTSP → HLS com latência < 3 segundos. Suporte a Intelbras, Hikvision e câmeras ONVIF genéricas.',
            tags: ['FFmpeg', 'RTSP → HLS', '< 3s latência'],
          },
          {
            icon: '⚡',
            title: 'WebSocket em Tempo Real',
            desc: 'Flask-SocketIO com Redis pub/sub transmite detecções do Worker para o browser em < 100ms.',
            tags: ['Socket.IO', 'Redis', '< 100ms'],
          },
          {
            icon: '🌐',
            title: 'ONNX no Browser',
            desc: 'Demo pública usa ONNX Runtime Web com WebGL acceleration. Inferência 100% no dispositivo do usuário.',
            tags: ['ONNX Runtime', 'WebGL', 'Privacidade'],
          },
        ].map(item => (
          <div class="bg-gray-50 rounded-2xl p-6">
            <div class="flex items-start gap-4">
              <span class="text-3xl">{item.icon}</span>
              <div>
                <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-500 text-sm leading-relaxed mb-4">{item.desc}</p>
                <div class="flex flex-wrap gap-2">
                  {item.tags.map(tag => (
                    <span class="text-xs bg-orange-100 text-orange-600 px-2 py-0.5 rounded-full font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Architecture diagram (text) -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Arquitetura do Sistema</h2>
      <div class="bg-white rounded-2xl p-8 shadow-sm font-mono text-sm text-gray-600 overflow-x-auto">
        <pre class="whitespace-pre">{`Câmera IP (RTSP)
    │
    ▼
Camera Gateway ──── FFmpeg ──── HLS Segments
    │
    ▼
Worker (Celery) ──── YOLOv8 Inference
    │
    ▼
Redis Pub/Sub ──── WS Gateway ──── Browser
    │
    ▼
PostgreSQL ──── API Flask ──── Frontend React`}</pre>
      </div>
    </div>
  </section>
</Layout>
